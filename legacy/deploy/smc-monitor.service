[Unit]
Description=SMC Monitor — Smart Money Concepts trading daemon
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/SMC_Monitor
ExecStart=/home/ubuntu/SMC_Monitor/deploy/run-monitor.sh
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
